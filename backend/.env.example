# 개발 기본값은 SQLite (별도 설치 불필요).
# 운영에서 PostgreSQL 사용 시 아래 주석을 해제해 변경하세요.
DATABASE_URL=sqlite:///./team_management.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/team_management

# JWT 서명 키 (운영에서는 반드시 임의의 긴 문자열로 교체)
SECRET_KEY=change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# 최초 실행 시 자동 생성되는 관리자 계정
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin1234
FIRST_ADMIN_NAME=관리자

# CORS 허용 오리진 (프론트 개발 서버)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
